<?xml version="1.0" encoding="UTF-8"?>
<configuration
        xmlns="http://ch.qos.logback/xml/ns/logback"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://ch.qos.logback/xml/ns/logback https://raw.githubusercontent.com/enricopulatzo/logback-XSD/master/src/main/xsd/logback.xsd"
        debug="true">
    <springProperty scope="context" name="APPLICATION_NAME" source="spring.application.name"/>
    <springProperty scope="context" name="APPLICATION_GROUP" source="spring.application.group"/>
    <property resource="custom.properties"/>

    <property name="LOG_CORRELATION_PATTERN" value="${HOSTNAME}"/>

    <property name="DEV_LOG_EXCEPTION_CONVERSION_WORD" value="${dev.logging.exception-conversion-word}"/>
    <property name="NONDEV_LOG_EXCEPTION_CONVERSION_WORD" value="${non-dev.logging.exception-conversion-word}"/>

    <property name="LOG_DATEFORMAT_PATTERN" value="ISO8601"/>

    <property name="COLORED_LOG_PATTERN_PREFIX" value="%clr(%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd'T'HH:mm:ss.SSSXXX}}){yellow} [%4.7relative] %highlight(%-5level) %clr(--- %esb{APPLICATION_GROUP}%esb{APPLICATION_NAME}%esb{PID}[${LOG_CORRELATION_PATTERN}] [%-1.15thread]){faint} in %clr(%-1.50logger{49}#%1.20method{19}\(%line\)){cyan}%clr(:){faint} %msg"/><!-- %maskedKvp{SINGLE} -->
    <property name="PLAIN_TEXT_LOG_PATTERN_PREFIX" value="%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd'T'HH:mm:ss.SSSXXX}} %-5level --- %esb{APPLICATION_GROUP}%esb{APPLICATION_NAME}%esb{PID}[${LOG_CORRELATION_PATTERN}] [%-1.15thread] in %-1.50logger{49}#%1.20method{19}\(%line\): %msg"/><!-- %maskedKvp{SINGLE} -->

    <!--    <property name="CONSOLE_LOG_PATTERN" value="%cyan(%d{dd-MM-yyyy HH:mm:ss.SSS}) %magenta([%thread]) %highlight(%-5level) %gray(%logger{36}.%M) - %msg%n"/>-->
    <property name="CONSOLE_LOG_CHARSET" value="UTF-8"/>

    <!--    <property name="FILE_LOG_PATTERN" value="%d{dd-MM-yyyy HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M - %msg%n"/>-->
    <property name="FILE_LOG_CHARSET" value="UTF-8"/>
    <property name="LOGBACK_ROLLINGPOLICY_MAX_FILE_SIZE" value="10MB"/>
    <property name="LOGBACK_ROLLINGPOLICY_TOTAL_SIZE_CAP" value="100MB"/>
    <property name="LOGBACK_ROLLINGPOLICY_MAX_HISTORY" value="10"/>

    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <springProfile name="default">
        <property name="CONSOLE_LOG_THRESHOLD" value="${default.logging.level.root:-ALL}"/>
        <property name="CONSOLE_LOG_PATTERN" value="${COLORED_LOG_PATTERN_PREFIX} ${DEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>

        <property name="FILE_LOG_THRESHOLD" value="${default.logging.level.root:-ALL}"/>
        <property name="FILE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${DEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>
        <property name="LOG_FILE" value="${LOG_PATH:-${java.io.tmpdir:-/tmp}}/java-application/log-level/default/${APPLICATION_NAME}.log"/>

        <logger name="org.tibor17.wwws" level="${default.logging.level.app:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="${default.logging.level.webfilter:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <root level="${default.logging.level.root:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
    <springProfile name="dev">
        <property name="CONSOLE_LOG_THRESHOLD" value="${dev.logging.level.root:-ALL}"/>
        <property name="CONSOLE_LOG_PATTERN" value="${COLORED_LOG_PATTERN_PREFIX} ${DEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>

        <property name="FILE_LOG_THRESHOLD" value="${dev.logging.level.root:-ALL}"/>
        <property name="FILE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${DEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>
        <property name="LOG_PATH" value="./target/logs"/>
        <property name="LOG_FILE" value="${LOG_PATH}/${APPLICATION_NAME}.log"/>

        <logger name="org.tibor17.wwws" level="${dev.logging.level.app:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="${dev.logging.level.webfilter:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <root level="${dev.logging.level.root:-ALL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
    <springProfile name="prod">
        <property name="CONSOLE_LOG_THRESHOLD" value="${prod.logging.level.root:-WARN}"/>
        <property name="CONSOLE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${NONDEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>

        <property name="FILE_LOG_THRESHOLD" value="${prod.logging.level.root:-WARN}"/>
        <property name="FILE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${NONDEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>
        <property name="LOG_PATH" value="/var/log/pods"/>
        <property name="LOG_FILE" value="${LOG_PATH}/${APPLICATION_NAME}.log"/>
        <property name="LOGBACK_ROLLINGPOLICY_CLEAN_HISTORY_ON_START" value="true"/>

        <logger name="org.tibor17.wwws" level="${prod.logging.level.app:-WARN}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="${prod.logging.level.webfilter:-TRACE}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <root level="${prod.logging.level.root:-WARN}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
    <springProfile name="!(default|dev|prod)">
        <property name="CONSOLE_LOG_THRESHOLD" value="${other.logging.level.root:-WARN}"/>
        <property name="CONSOLE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${NONDEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>

        <property name="FILE_LOG_THRESHOLD" value="${other.logging.level.root:-WARN}"/>
        <property name="FILE_LOG_PATTERN" value="${PLAIN_TEXT_LOG_PATTERN_PREFIX} ${NONDEV_LOG_EXCEPTION_CONVERSION_WORD:-%wEx}%n"/>
        <property name="LOG_FILE" value="${java.io.tmpdir:-/tmp}/java-application/log-level/other/${APPLICATION_NAME}.log"/>
        <property name="LOGBACK_ROLLINGPOLICY_CLEAN_HISTORY_ON_START" value="true"/>

        <logger name="org.tibor17.wwws" level="${other.logging.level.app:-INFO}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="org.springframework.web.filter.CommonsRequestLoggingFilter" level="${other.logging.level.webfilter:-TRACE}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>
        <root level="${other.logging.level.root:-INFO}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!--
    Inherited from defaults.xml.
    Override the log level as necessary.
    -->
    <logger name="org.apache.catalina.startup.DigesterFactory" level="ERROR"/>
    <logger name="org.apache.catalina.util.LifecycleBase" level="ERROR"/>
    <logger name="org.apache.coyote.http11.Http11NioProtocol" level="WARN"/>
    <logger name="org.apache.sshd.common.util.SecurityUtils" level="WARN"/>
    <logger name="org.apache.tomcat.util.net.NioSelectorPool" level="WARN"/>
    <logger name="org.eclipse.jetty.util.component.AbstractLifeCycle" level="ERROR"/>
    <logger name="org.hibernate.validator.internal.util.Version" level="WARN"/>
    <logger name="org.springframework.boot.actuate.endpoint.jmx" level="WARN"/>

    <shutdownHook class="ch.qos.logback.core.hook.DefaultShutdownHook"/>
</configuration>